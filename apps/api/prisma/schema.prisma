generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  REPORTER
  MODERATOR
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

enum MediaType {
  IMAGE
  VIDEO
  PDF
}

enum SectionType {
  HERO
  ROW
  GALLERY
  VIDEO
  HEADLINES
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(REPORTER)
  avatar    String?
  bio       String?
  active    Boolean   @default(true)
  articles  Article[] @relation("ArticleAuthor")
  media     Media[]
  logs      ActivityLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id        String     @id @default(cuid())
  name      String
  nameEn    String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  order     Int        @default(0)
  visible   Boolean    @default(true)
  articles  Article[]
  sections  HomepageSection[]
  createdAt DateTime   @default(now())
}

model Tag {
  id       String    @id @default(cuid())
  name     String
  nameEn   String
  slug     String    @unique
  articles Article[]
}

model Article {
  id             String        @id @default(cuid())
  title          String
  titleEn        String
  slug           String        @unique
  excerpt        String
  excerptEn      String
  body           String        @db.Text
  bodyEn         String        @db.Text
  status         ArticleStatus @default(DRAFT)
  isBreaking     Boolean       @default(false)
  featured       Boolean       @default(false)
  isHero         Boolean       @default(false)
  imageTone      String        @default("navy")
  featuredImage  String?
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  authorId       String
  author         User          @relation("ArticleAuthor", fields: [authorId], references: [id])
  authorName     String?
  tags           Tag[]
  viewCount      Int           @default(0)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  publishedAt    DateTime?
  comments       Comment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([categoryId])
  @@index([status])
}

model Media {
  id           String    @id @default(cuid())
  url          String
  type         MediaType @default(IMAGE)
  altText      String?
  uploadedById String?
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
}

model BreakingItem {
  id        String    @id @default(cuid())
  text      String
  textEn    String
  order     Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model HomepageSection {
  id         String      @id @default(cuid())
  type       SectionType
  title      String?
  titleEn    String?
  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id])
  cardCount  Int         @default(6)
  order      Int         @default(0)
  visible    Boolean     @default(true)
}

model LiveTvSetting {
  id        String   @id @default("live-tv")
  streamUrl String   @default("")
  active    Boolean  @default(false)
  title     String   @default("লাইভ টিভি")
  titleEn   String   @default("Live TV")
  updatedAt DateTime @updatedAt
}

model EpaperEdition {
  id        String   @id @default(cuid())
  date      DateTime
  pdfUrl    String
  thumbnail String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model District {
  id       String       @id @default(cuid())
  name     String
  nameEn   String
  slug     String       @unique
  division String
  lawyers  Lawyer[]
  donors   BloodDonor[]
}

model Lawyer {
  id         String   @id @default(cuid())
  name       String
  spec       String
  specEn     String
  phone      String
  chamber    String?
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  createdAt  DateTime @default(now())
}

model BloodDonor {
  id           String    @id @default(cuid())
  name         String
  group        String
  phone        String
  districtId   String
  district     District  @relation(fields: [districtId], references: [id])
  lastDonation DateTime?
  createdAt    DateTime  @default(now())
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Comment {
  id        String        @id @default(cuid())
  articleId String
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  body      String
  status    CommentStatus @default(PENDING)
  parentId  String?
  createdAt DateTime      @default(now())

  @@index([articleId])
  @@index([status])
}

model MenuItem {
  id       String     @id @default(cuid())
  label    String
  labelEn  String
  href     String?
  order    Int        @default(0)
  parentId String?
  parent   MenuItem?  @relation("MenuTree", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuTree")
  visible  Boolean    @default(true)
}

model AdSlot {
  id        String   @id @default(cuid())
  name      String
  placement String
  imageUrl  String?
  linkUrl   String?
  html      String?  @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SiteSetting {
  key   String @id
  value Json
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  createdAt DateTime @default(now())

  @@index([userId])
}
